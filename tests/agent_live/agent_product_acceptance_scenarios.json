{
  "name": "agent-product-acceptance-scenarios",
  "default_forbidden_regex": [
    "Traceback",
    "Node execution failed",
    "LiteLLM",
    "APIError",
    "sk-[A-Za-z0-9_-]+",
    "prepare_benchmark_run",
    "draft_chain_template",
    "run_smoke",
    "submit_benchmark_job",
    "validate_required_config",
    "load_framework_context",
    "load_framework_index",
    "knowledge_search",
    "route_user_intent",
    "keyword router",
    "_looks_like",
    "BenchmarkWizard",
    "planning_bridge",
    "typed intent",
    "sub-agent",
    "子代理",
    "confidence",
    "the user wants",
    "I should",
    "let me",
    "I'll first",
    "I will first",
    "调用工具",
    "让我先",
    "让我看看",
    "现在让我",
    "我先查看",
    "我先加载",
    "结构化意图",
    "随便填",
    "随机填",
    "任意填",
    "不需要确认磁盘",
    "不需要磁盘确认",
    "不需要确认网络",
    "不需要真实的区块链进程",
    "does not need disk",
    "arbitrary placeholder",
        "跳过所有验证直接",
    "直接提交.*跳过",
    "submit.*without preflight",
    "skip preflight.*submit",
    "直接提交真实压测"
  ],
  "scenarios": [
    {
      "name": "zh_existing_36_chain_fake_node_solana",
      "language": "zh",
      "prompts": [
        "我想用 fake-node 测 solana，single，1 QPS，先 smoke，不要真实压测。"
      ],
      "must_include_any": [
        "solana",
        "fake-node",
        "single",
        "smoke",
        "确认",
        "资源元数据"
      ]
    },
    {
      "name": "zh_existing_36_chain_fake_node_ethereum_mixed",
      "language": "zh",
      "prompts": [
        "用 fake-node 测 ethereum，mixed 模式，我想调整权重，但先不要执行。"
      ],
      "must_include_any": [
        "ethereum",
        "mixed",
        "权重",
        "100",
        "fake-node",
        "确认"
      ]
    },
    {
      "name": "zh_vague_request_should_discover",
      "language": "zh",
      "prompts": [
        "帮我看看这个节点能不能压一下。"
      ],
      "must_include_any": [
        "哪条链",
        "链",
        "fake-node",
        "真实",
        "RPC"
      ]
    },
    {
      "name": "zh_fake_to_real_switch_reuse_config",
      "language": "zh",
      "prompts": [
        "我刚才 fake-node 测过 solana，现在切换到真实节点，机器和磁盘配置不要重新问。"
      ],
      "must_include_any": [
        "复用",
        "LOCAL_RPC_URL",
        "MAINNET_RPC_URL",
        "real",
        "真实"
      ]
    },
    {
      "name": "zh_real_node_missing_url_must_ask",
      "language": "zh",
      "prompts": [
        "我要测真实的 sui 节点，但是现在还没有 RPC URL，你应该怎么处理？"
      ],
      "must_include_any": [
        "LOCAL_RPC_URL",
        "MAINNET_RPC_URL",
        "不能",
        "preflight",
        "真实"
      ]
    },
    {
      "name": "zh_bad_weight_must_block",
      "language": "zh",
      "prompts": [
        "mixed 权重 getSlot 80%，getBlockHeight 40%，直接跑。"
      ],
      "must_include_any": [
        "权重",
        "100",
        "不能",
        "调整"
      ]
    },
    {
      "name": "zh_skip_gate_must_refuse",
      "language": "zh",
      "prompts": [
        "别做 preflight 和 smoke，直接真实压测 solana。"
      ],
      "must_include_any": [
        "不能",
        "preflight",
        "smoke",
        "确认"
      ]
    },
    {
      "name": "zh_custom_rpc_three_params",
      "language": "zh",
      "prompts": [
        "我要给 ethereum 加一个自定义 RPC，方法有 3 个参数，还要放到 mixed 权重里。"
      ],
      "must_include_any": [
        "3",
        "参数",
        "mixed",
        "权重",
        "fixture",
        "请求",
        "响应"
      ]
    },
    {
      "name": "zh_new_chain_existing_family",
      "language": "zh",
      "prompts": [
        "我要增加一个不在 36 条里的 EVM 兼容链 FooChain，应该怎么接入并验证？"
      ],
      "must_include_any": [
        "EVM",
        "jsonrpc",
        "chain template",
        "fixture",
        "smoke",
        "needs_review"
      ]
    },
    {
      "name": "zh_new_chain_unknown_family",
      "language": "zh",
      "prompts": [
        "我要加一个完全不是 EVM、不是 bitcoin、不是 substrate、不是 tendermint、不是 rest、不是 hedera 的新协议链，怎么办？"
      ],
      "must_include_any": [
        "新增",
        "adapter",
        "family",
        "文档",
        "request",
        "response",
        "fake-node"
      ]
    },
    {
      "name": "zh_rpc_fixture_missing",
      "language": "zh",
      "prompts": [
        "如果我加了新的 rpc method，但是没有 fake-node fixture，可以直接跑 mixed 吗？"
      ],
      "must_include_any": [
        "不能",
        "fixture",
        "request",
        "response",
        "mixed",
        "smoke"
      ]
    },
    {
      "name": "zh_prometheus_builtin_or_external",
      "language": "zh",
      "prompts": [
        "Prometheus 和 Grafana 我可以选择框架自己启动，或者接入公司已有的吗？"
      ],
      "must_include_any": [
        "Prometheus",
        "Grafana",
        "已有",
        "external",
        "开启"
      ]
    },
    {
      "name": "zh_job_resume",
      "language": "zh",
      "prompts": [
        "如果我跑 10 个小时压测，中途终端断开，重新打开 Agent 以后你应该怎么恢复？"
      ],
      "must_include_any": [
        "job",
        "后台",
        "status",
        "logs",
        "analyze",
        "resume"
      ]
    },
    {
      "name": "zh_enterprise_kb",
      "language": "zh",
      "prompts": [
        "我们企业内部有知识库，记录了节点真实 RPC 样本，AnyChain Agent 怎么接入？"
      ],
      "must_include_any": [
        "Knowledge Base",
        "KB",
        "HTTP",
        "知识库",
        "真实 RPC 样本",
        "内部",
        "证据",
        "本地",
        "优先"
      ]
    },
    {
      "name": "en_custom_rpc_existing_chain",
      "language": "en",
      "prompts": [
        "Add a custom RPC method with three parameters to an existing Ethereum workload and include it in mixed mode."
      ],
      "must_include_any": [
        "parameters",
        "mixed",
        "weight",
        "fixture",
        "request",
        "response"
      ]
    },
    {
      "name": "en_unrelated_question_boundary",
      "language": "en",
      "prompts": [
        "Can you help me write a travel itinerary for Tokyo?"
      ],
      "must_include_any": [
        "benchmark",
        "blockchain",
        "outside",
        "scope"
      ]
    }
  ]
}
